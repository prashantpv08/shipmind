{
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "build": "next build",
    "demo:reset": "node scripts/demo-reset.mjs",
    "sandbox:build": "tsc -p sandbox/notification-service/workspace/tsconfig.json --noEmit",
    "sandbox:test:unit": "vitest run --config sandbox/notification-service/workspace/vitest.config.ts sandbox/notification-service/workspace/tests/notification-service.unit.test.ts",
    "sandbox:test:api": "vitest run --config sandbox/notification-service/workspace/vitest.config.ts sandbox/notification-service/workspace/tests/notification-service.api.test.ts",
    "sandbox:test": "vitest run --config sandbox/notification-service/workspace/vitest.config.ts sandbox/notification-service/workspace/tests",
    "sandbox:coverage": "vitest run --config sandbox/notification-service/workspace/vitest.config.ts sandbox/notification-service/workspace/tests --coverage.enabled=true --coverage.provider=v8 --coverage.reporter=json-summary --coverage.reporter=text --coverage.reportsDirectory=sandbox/notification-service/workspace/coverage",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node --import tsx scripts/db-seed.ts",
    "db:reset": "node --import tsx scripts/db-reset.ts",
    "db:test": "TEST_DATABASE_URL=postgresql://axiom:axiom-local-only@localhost:54329/axiom_test vitest run tests/postgres.integration.test.ts",
    "db:import:dry-run": "node --import tsx scripts/import-prototype-data.ts --dry-run",
    "db:import": "node --import tsx scripts/import-prototype-data.ts --apply",
    "db:verify-import": "node --import tsx scripts/verify-prototype-import.ts"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "0.18.1",
    "@vercel/blob": "^2.6.1",
    "@vercel/sandbox": "^2.7.1",
    "@vitejs/plugin-react": "6.0.3",
    "drizzle-orm": "^0.45.2",
    "mammoth": "1.12.0",
    "mermaid": "11.16.0",
    "next": "16.2.10",
    "openai": "6.47.0",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "unpdf": "1.6.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "10.5.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "postcss": "8.5.19",
    "tailwindcss": "4.3.3",
    "tsx": "^4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=22.0.0"
  }
}
